custom-shader = shaders/cursor-smear.glsl
# custom-shader = shaders/bloom.glsl
# custom-shader = shaders/cosmic-bg.glsl

font-feature = -calt, -liga, -dlig
cursor-style-blink = false

keybind = ctrl+backspace=text:\x17
keybind = ctrl+shift+f=toggle_fullscreen
keybind = ctrl+shift+n=unbind
keybind = ctrl+alt+n=new_window

# theme = Catppuccin Mocha
# theme = Carbonfox
theme = TokyoNight Night
